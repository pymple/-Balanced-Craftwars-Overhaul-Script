-- ==================== INPUT HANDLER ====================
AddConnection(UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed or IsTyping() then return end
    if input.KeyCode == Enum.KeyCode.V then
        ToggleAutoSwing()
    elseif input.KeyCode == Enum.KeyCode.B then
        ToggleAutoGun()
    elseif input.KeyCode == Enum.KeyCode.N then
        ToggleAutoTeleport()
    end
end))

-- ==================== MAIN LOOPS ====================
AddConnection(RunService.RenderStepped:Connect(function()
    if Flags.AutoTeleport then TeleportToTarget() end
end))

AddConnection(RunService.Heartbeat:Connect(function(dt)
    SwingTimer = SwingTimer + dt
    GunTimer = GunTimer + dt
    SpeedTimer = SpeedTimer + dt

    if Flags.SpeedEnforce and SpeedTimer >= 0.5 then
        SpeedTimer = 0
        ApplyMovementStats()
    end

    if Flags.AutoSwing and SwingTimer >= Flags.SwingCooldown then
        SwingTimer = 0
        task.spawn(PerformSwordAttack)
    end

    if Flags.AutoGun and GunTimer >= Flags.GunCooldown then
        GunTimer = 0
        task.spawn(PerformGunAttack)
    end
end))

