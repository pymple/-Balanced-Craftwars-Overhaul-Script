local function IsValidEnemy(obj)
    if not obj or not obj:IsA("Model") then return false end
    if IsPlayerCharacter(obj) then return false end
    local hum = obj:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if IsCraftwarsAlly(obj) then return false end
    if IsAnySummon(obj) then return false end
    return true
end

local function GetAllEnemies()
    local enemies = {}
    for _, obj in ipairs(workspace:GetChildren()) do
        if IsValidEnemy(obj) then table.insert(enemies, obj) end
    end
    local enemyFolders = {"Enemies", "NPCs", "Mobs", "Zombies", "monsters", "Monster", "Bosses"}
    for _, folderName in ipairs(enemyFolders) do
        local folder = workspace:FindFirstChild(folderName)
        if folder then
            for _, obj in ipairs(folder:GetChildren()) do
                if IsValidEnemy(obj) then table.insert(enemies, obj) end
            end
        end
    end
    return enemies
end

local function GetAllSummons()
    local summons = {}
    local seen = {}
    local function Scan(container)
        for _, obj in ipairs(container:GetChildren()) do
            if not seen[obj] and obj:IsA("Model") and not IsPlayerCharacter(obj) then
                local hum = obj:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 and (IsCraftwarsAlly(obj) or IsAnySummon(obj)) then
                    seen[obj] = true
                    table.insert(summons, obj)
                end
            end
        end
    end
    Scan(workspace)
    local folders = {"Summons", "Minions", "Pets", "Allies", "Enemies", "NPCs", "Mobs"}
    for _, name in ipairs(folders) do
        local folder = workspace:FindFirstChild(name)
        if folder then Scan(folder) end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        local folder = workspace:FindFirstChild(p.Name)
        if folder then Scan(folder) end
    end
    return summons
end

