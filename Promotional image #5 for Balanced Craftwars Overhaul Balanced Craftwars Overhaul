local function UpdateToggleState(toggle, value)
    if not toggle then return end
    pcall(function()
        if toggle.Set then toggle:Set(value)
        elseif toggle.SetValue then toggle:SetValue(value)
        elseif toggle.SetState then toggle:SetState(value) end
        if toggle.Refresh then toggle:Refresh()
        elseif toggle.Update then toggle:Update() end
    end)
end

