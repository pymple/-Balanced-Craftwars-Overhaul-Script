SpeedSection:AddButton({
    Name = "Show Weapon Stats",
    Callback = function()
        local stats = GetWeaponStats()
        if stats then
            local msg = ""
            if stats.Damage then msg = msg .. "Damage: " .. stats.Damage .. "\n" end
            if stats.CritDamage then msg = msg .. "Crit Damage: " .. stats.CritDamage .. "\n" end
            if stats.CritChance then msg = msg .. "Crit Chance: " .. stats.CritChance .. "%\n" end
            if stats.Speed then msg = msg .. "Speed: " .. stats.Speed end
            Notifier.new({Title = "Weapon Stats", Content = msg, Duration = 5, Icon = AVATAR_ICON})
        else
            Notifier.new({Title = "Error", Content = "No weapon equipped", Duration = 2, Icon = AVATAR_ICON})
        end
    end
})

SpeedSection:AddButton({
    Name = "Debug Weapon Remotes",
    Callback = function()
        local tool = GetEquippedTool()
        if not tool then
            Notifier.new({Title = "Error", Content = "No weapon equipped", Duration = 2, Icon = AVATAR_ICON})
            return
        end
        local info = "Tool: " .. tool.Name
        local hasRF = tool:FindFirstChild("RemoteFunction") and "Yes" or "No"
        local hasRE = tool:FindFirstChild("RemoteEvent") and "Yes" or "No"
        info = info .. "\nRemoteFunction: " .. hasRF
        info = info .. "\nRemoteEvent: " .. hasRE
        local isShoot = tool:FindFirstChild("GunThrowerMain") ~= nil
            or tool:FindFirstChild("RangedSpread") ~= nil
            or tool:FindFirstChild("RangedPower") ~= nil
        info = info .. "\nShoot-type gun: " .. (isShoot and "Yes" or "No")
        info = info .. "\nChildren:"
        for _, c in ipairs(tool:GetChildren()) do
            info = info .. "\n  " .. c.Name .. " [" .. c.ClassName .. "]"
        end
        Notifier.new({Title = "Weapon Debug", Content = info, Duration = 10, Icon = AVATAR_ICON})
    end
})

