local function ActivateSummonerTool(tool)
    if not tool then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    local currentTool = GetEquippedTool()
    local previousWeapon = nil
    if currentTool and currentTool ~= tool and not IsSummonerTool(currentTool) then
        previousWeapon = currentTool.Name
    end

    if currentTool ~= tool then
        hum:EquipTool(tool)
        task.wait(0.15)
    end

    pcall(function() tool:Activate() end)

    local rf = tool:FindFirstChild("RemoteFunction")
    if rf then
        pcall(function() rf:InvokeServer("hit", {80, 1}) end)
    end

    local re = tool:FindFirstChild("RemoteEvent")
    if re then
        pcall(function() re:FireServer("hit", {80, 1}) end)
    end

    if previousWeapon then
        task.delay(0.3, function()
            EquipWeaponByName(previousWeapon)
        end)
    elseif LastEquippedWeapon then
        task.delay(0.3, function()
            EquipWeaponByName(LastEquippedWeapon)
        end)
    end
end

