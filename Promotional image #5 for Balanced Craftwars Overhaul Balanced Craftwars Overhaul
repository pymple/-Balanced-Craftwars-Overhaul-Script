AddConnection(UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed or IsTyping() then return end
    if input.KeyCode == Enum.KeyCode.V then ToggleAutoSwing()
    elseif input.KeyCode == Enum.KeyCode.B then ToggleAutoGun()
    elseif input.KeyCode == Enum.KeyCode.N then ToggleAutoTeleport() end
end))

AddConnection(RunService.RenderStepped:Connect(function()
    if Flags.AutoTeleport then TeleportToTarget() end
end))

AddConnection(RunService.Heartbeat:Connect(function(dt)
    SwingTimer = SwingTimer + dt
    GunTimer = GunTimer + dt
    SpeedTimer = SpeedTimer + dt
    ESPTimer = ESPTimer + dt
    SummonTimer = SummonTimer + dt

    if Flags.SpeedEnforce and SpeedTimer >= 0.5 then
        SpeedTimer = 0
        ApplyMovementStats()
    end

    if Flags.AutoSwing and SwingTimer >= Flags.SwingCooldown then
        SwingTimer = 0
        task.spawn(PerformSwordAttack)
    end

    local effectiveGunCD = GetEffectiveGunCooldown()
    if Flags.AutoGun and GunTimer >= effectiveGunCD then
        GunTimer = 0
        task.spawn(PerformGunAttack)
    end

    if (Flags.EnemyESP or Flags.AllyESP) and ESPTimer >= 2 then
        ESPTimer = 0
        task.spawn(UpdateESP)
    end

    if Flags.AutoSummon and SummonTimer >= Flags.SummonCooldown then
        SummonTimer = 0
        task.spawn(TryAutoSummon)
    end
end))

task.spawn(SetupChatListener)
