    if espType == "summon" then
        nameColor = Color3.fromRGB(100, 255, 100)
        hpColor = Color3.fromRGB(150, 255, 150)
        fillColor = Color3.fromRGB(0, 200, 0)
        outlineColor = Color3.fromRGB(100, 255, 100)
    elseif isBoss then
        nameColor = Color3.fromRGB(255, 50, 50)
        hpColor = Color3.fromRGB(255, 150, 150)
        fillColor = Color3.fromRGB(255, 0, 0)
        outlineColor = Color3.fromRGB(255, 50, 50)
    else
        nameColor = Color3.fromRGB(255, 80, 80)
        hpColor = Color3.fromRGB(255, 80, 80)
        fillColor = Color3.fromRGB(200, 0, 0)
        outlineColor = Color3.fromRGB(255, 80, 80)
