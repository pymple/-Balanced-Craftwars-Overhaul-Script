local function IsCraftwarsAlly(obj)
    if not obj or not obj:IsA("Model") then return false end
    if obj:FindFirstChild("AlliedSummon") then return true end
    if obj:FindFirstChild("SummonMain") and obj:FindFirstChild("OwnerTag") then return true end
    if obj:FindFirstChild("SummonLife") and obj:FindFirstChild("SummonPower") then return true end
    if obj:FindFirstChild("nopvp") and obj:FindFirstChild("SummonTime") then return true end
    return false
end

local function IsSummonOwnedByPlayer(obj, player)
    if not obj then return false end
    local ownerTag = obj:FindFirstChild("OwnerTag")
    if ownerTag then
        if ownerTag:IsA("ObjectValue") and ownerTag.Value == player then return true end
        if ownerTag:IsA("StringValue") then
            if ownerTag.Value == player.Name or ownerTag.Value == tostring(player.UserId) then return true end
        end
    end
    local owner = obj:FindFirstChild("Owner") or obj:FindFirstChild("Summoner") or obj:FindFirstChild("Creator")
    if owner then
        if owner:IsA("ObjectValue") and owner.Value == player then return true end
        if owner:IsA("StringValue") then
            if owner.Value == player.Name or owner.Value == tostring(player.UserId) then return true end
        end
        if owner:IsA("IntValue") and owner.Value == player.UserId then return true end
    end
    return false
end

local function IsAnySummon(obj)
    if not obj or not obj:IsA("Model") then return false end
    if IsCraftwarsAlly(obj) then return true end
    local ownerVal = obj:FindFirstChild("Owner") or obj:FindFirstChild("Summoner") or obj:FindFirstChild("Creator")
        or obj:FindFirstChild("OwnerTag") or obj:FindFirstChild("SummonedBy")
    if ownerVal then
        if ownerVal:IsA("ObjectValue") and ownerVal.Value and ownerVal.Value:IsA("Player") then return true end
        if ownerVal:IsA("StringValue") then
            for _, p in ipairs(Players:GetPlayers()) do
                if ownerVal.Value == p.Name or ownerVal.Value == tostring(p.UserId) then return true end
            end
        end
    end
    local nameLower = obj.Name:lower()
    if nameLower:find("summon", 1, true) or nameLower:find("minion", 1, true) or nameLower:find("ally", 1, true) then
        return true
    end
    local parent = obj.Parent
    if parent then
        local parentName = parent.Name:lower()
        if parentName:find("summon", 1, true) or parentName:find("minion", 1, true) then return true end
        for _, p in ipairs(Players:GetPlayers()) do
            if parent.Name == p.Name then return true end
        end
    end
    return false
end

local function IsMySummon(obj)
    if not obj or not obj:IsA("Model") then return false end
    if IsCraftwarsAlly(obj) and IsSummonOwnedByPlayer(obj, LocalPlayer) then return true end
    if IsCraftwarsAlly(obj) then
        local objPart = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
        local char = LocalPlayer.Character
        if objPart and char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp and (hrp.Position - objPart.Position).Magnitude < 40 then
                local closestPlayer, closestDist = nil, math.huge
                for _, p in ipairs(Players:GetPlayers()) do
                    if p.Character then
                        local pHRP = p.Character:FindFirstChild("HumanoidRootPart")
                        if pHRP then
                            local d = (pHRP.Position - objPart.Position).Magnitude
                            if d < closestDist then closestDist = d closestPlayer = p end
                        end
                    end
                end
                if closestPlayer == LocalPlayer then return true end
            end
        end
    end
    return false
end

