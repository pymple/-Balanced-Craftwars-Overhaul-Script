local function TeleportToTarget()
    if not Flags.AutoTeleport then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local target = GetCurrentTarget()
    if not target then return end
    local enemyPart = GetEnemyHRP(target)
    if not enemyPart then return end
    local enemyPos = enemyPart.Position
    local enemyCF = enemyPart.CFrame
    local distance = Flags.TeleportDistance
    local targetCF
    if Flags.TeleportPosition == "Back" then
        targetCF = enemyCF * CFrame.new(0, 0, distance)
    elseif Flags.TeleportPosition == "Front" then
        targetCF = enemyCF * CFrame.new(0, 0, -distance)
    elseif Flags.TeleportPosition == "Left" then
        targetCF = enemyCF * CFrame.new(-distance, 0, 0)
    elseif Flags.TeleportPosition == "Right" then
        targetCF = enemyCF * CFrame.new(distance, 0, 0)
    elseif Flags.TeleportPosition == "Top" then
        targetCF = enemyCF * CFrame.new(0, distance, 0)
    else
        targetCF = enemyCF * CFrame.new(0, 0, distance)
    end
    hrp.CFrame = CFrame.lookAt(targetCF.Position, enemyPos)
    hrp.Velocity = Vector3.new(0, 0, 0)
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
end

local function PerformSwordAttack()
    local tool = GetEquippedTool()

    -- If no tool equipped or current tool is a summoner, find a melee weapon to equip
    if not tool or IsSummonerTool(tool) then
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        if backpack then
            -- First pass: prefer melee weapons (has RF but no RE)
            for _, item in ipairs(backpack:GetChildren()) do
                if item:IsA("Tool") and not IsSummonerTool(item) then
                    local rf = item:FindFirstChild("RemoteFunction")
                    if rf and not item:FindFirstChild("RemoteEvent") then
                        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                        if hum then hum:EquipTool(item) end
                        tool = item
                        break
                    end
                end
            end
            -- Fallback: equip any non-summoner tool with a RemoteFunction
            if not tool or IsSummonerTool(tool) then
                for _, item in ipairs(backpack:GetChildren()) do
                    if item:IsA("Tool") and not IsSummonerTool(item) and item:FindFirstChild("RemoteFunction") then
                        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                        if hum then hum:EquipTool(item) end
                        tool = item
                        break
                    end
                end
            end
        end
    end

    if not tool then return end
    if IsSummonerTool(tool) then return end
    local rf = tool:FindFirstChild("RemoteFunction")
    if not rf then return end
    if not GetCurrentTarget() then return end
    LastEquippedWeapon = tool.Name
    pcall(function() rf:InvokeServer("hit", {80, 1}) end)
end

local function GetToolFirePoint(tool)
    if not tool then return nil end
    local barrel = tool:FindFirstChild("Barrel") or tool:FindFirstChild("Muzzle") or tool:FindFirstChild("FirePoint") or tool:FindFirstChild("ShootPart")
    if barrel and barrel:IsA("BasePart") then return barrel end
    local handle = tool:FindFirstChild("Handle")
    if handle and handle:IsA("BasePart") then return handle end
    return nil
end

local function PerformGunAttack()
    local tool = GetEquippedTool()

    -- If no tool equipped or current tool is a summoner, find a gun to equip
    if not tool or IsSummonerTool(tool) then
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        if backpack then
            -- First pass: prefer guns (has RemoteEvent)
            for _, item in ipairs(backpack:GetChildren()) do
                if item:IsA("Tool") and not IsSummonerTool(item) then
                    local re = item:FindFirstChild("RemoteEvent")
                    if re then
                        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                        if hum then hum:EquipTool(item) end
                        tool = item
                        break
                    end
                end
            end
            -- Fallback: equip any non-summoner tool
            if not tool or IsSummonerTool(tool) then
                for _, item in ipairs(backpack:GetChildren()) do
                    if item:IsA("Tool") and not IsSummonerTool(item) then
                        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                        if hum then hum:EquipTool(item) end
                        tool = item
                        break
                    end
                end
            end
        end
    end

    if not tool then return end
    if IsSummonerTool(tool) then return end
    local target = GetCurrentTarget()
    if not target then return end
    local targetPos = GetEnemyPosition(target)
    if not targetPos then return end
    LastEquippedWeapon = tool.Name
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local re = tool:FindFirstChild("RemoteEvent")
    local rf = tool:FindFirstChild("RemoteFunction")
    local dmgVal = tool:FindFirstChild("Damage")
    local dmg = dmgVal and dmgVal.Value or 20

    local enemyHRP = GetEnemyHRP(target)
    if enemyHRP then targetPos = enemyHRP.Position end

    local firePoint = GetToolFirePoint(tool)
    local firePos = firePoint and firePoint.Position or hrp.Position
    local aimCF = CFrame.lookAt(firePos, targetPos)

    if re then
