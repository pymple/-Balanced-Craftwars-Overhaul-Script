-- ==================== ITEM TRACKER SYSTEM ====================
-- ONLY tracks items from chat messages. Does NOT track backpack equip/unequip.

local function FormatTimeAgo(timestamp)
    local elapsed = tick() - timestamp
    if elapsed < 60 then return math.floor(elapsed) .. "s ago" end
    if elapsed < 3600 then return math.floor(elapsed / 60) .. "m ago" end
    return math.floor(elapsed / 3600) .. "h ago"
end

local function GetFilteredItems()
    if ItemSearchQuery == "" then return ItemLog end
    local filtered = {}
    local query = ItemSearchQuery:lower()
    for _, entry in ipairs(ItemLog) do
        if entry.name:lower():find(query, 1, true) then
            table.insert(filtered, entry)
        end
    end
    return filtered
end

local function BuildItemListText()
    local items = GetFilteredItems()
    if #items == 0 then
        if ItemSearchQuery ~= "" then
            return 'No items matching "' .. ItemSearchQuery .. '"'
        end
        return "Waiting for drops..."
    end

    local lines = {}

    -- Centered header line (no dashes)
    local header = "[ " .. #ItemLog .. " unique  |  " .. TotalItemsCollected .. " total ]"
    table.insert(lines, header)
    table.insert(lines, "") -- blank line spacer

    for _, entry in ipairs(items) do
        local line = "x" .. entry.totalQty .. "  " .. entry.name
        table.insert(lines, line)
    end

    return table.concat(lines, "\n")
end

function RefreshItemList()
    if not ItemListParagraph then return end
    pcall(function()
        local text = BuildItemListText()
        if ItemListParagraph.SetContent then
            ItemListParagraph:SetContent(text)
        elseif ItemListParagraph.Set then
            ItemListParagraph:Set(text)
        elseif ItemListParagraph.SetText then
            ItemListParagraph:SetText(text)
        end
    end)
end

local function CleanMessage(text)
    if not text then return "" end
    local clean = text:gsub("<.->", "")
    clean = clean:gsub("^%s+", ""):gsub("%s+$", "")
    return clean
end

local function ParseItemMessage(raw)
    local message = CleanMessage(raw)
    if message == "" then return nil, nil end

    local qty, itemName = message:match("You got (%d+) (.+)!")
    if qty and itemName then return itemName, tonumber(qty) end

    itemName = message:match("You got (.+)!")
    if itemName then return itemName, 1 end

    qty, itemName = message:match("You received (%d+) (.+)")
    if qty and itemName then return itemName:gsub("!$", ""), tonumber(qty) end

    itemName = message:match("You received (.+)")
    if itemName then return itemName:gsub("!$", ""), 1 end

    itemName, qty = message:match("Obtained: (.+) %(x(%d+)%)")
    if itemName and qty then return itemName, tonumber(qty) end

    itemName = message:match("Obtained: (.+)")
    if itemName then return itemName:gsub("!$", ""), 1 end

    qty, itemName = message:match("^%+(%d+)%s+(.+)")
    if qty and itemName then return itemName:gsub("!$", ""), tonumber(qty) end

    itemName = message:match("Dropped: (.+)")
    if itemName then return itemName:gsub("!$", ""), 1 end

    itemName, qty = message:match("%[Item%]%s*(.+)%s+x(%d+)")
    if itemName and qty then return itemName, tonumber(qty) end

    itemName = message:match("%[Item%]%s*(.+)")
    if itemName then return itemName:gsub("!$", ""), 1 end

    return nil, nil
end

local function MakeDedup(text)
    return text .. "|" .. tostring(math.floor(tick() * 2))
end

local function RegisterItem(itemName, quantity)
    if not itemName or itemName == "" then return end
    quantity = quantity or 1
    TotalItemsCollected = TotalItemsCollected + quantity

    if ItemLogMap[itemName] then
        local idx = ItemLogMap[itemName]
        ItemLog[idx].totalQty = ItemLog[idx].totalQty + quantity
        ItemLog[idx].lastTime = tick()
        ItemLog[idx].drops = ItemLog[idx].drops + 1
    else
        table.insert(ItemLog, 1, {
            name = itemName,
            totalQty = quantity,
            lastTime = tick(),
            drops = 1,
        })

        while #ItemLog > MAX_ITEMS do
            table.remove(ItemLog, #ItemLog)
        end

        ItemLogMap = {}
        for i, e in ipairs(ItemLog) do
            ItemLogMap[e.name] = i
        end
    end

    RefreshItemList()
end

local function OnItemMessage(rawText)
    if not rawText or rawText == "" then return end
    local clean = CleanMessage(rawText)
    if clean == "" then return end

    local key = MakeDedup(clean)
    if ProcessedMessages[key] then return end
    ProcessedMessages[key] = true

    local count = 0
    for _ in pairs(ProcessedMessages) do count = count + 1 end
    if count > MAX_PROCESSED then
        ProcessedMessages = {}
    end

    local itemName, qty = ParseItemMessage(clean)
    if itemName then
        RegisterItem(itemName, qty)
    end
end

local function MightBeItemDrop(text)
    if not text or text == "" then return false end
    local lower = text:lower()
    return lower:find("you got")
        or lower:find("you received")
        or lower:find("obtained")
        or lower:find("%+%d+%s+%a")
        or lower:find("dropped:")
        or lower:find("%[item%]")
end

-- ==================== CHAT LISTENER (CHAT ONLY — NO BACKPACK) ====================

local function SetupChatListener()
    pcall(function()
        if TextChatService then
            AddConnection(TextChatService.MessageReceived:Connect(function(textChatMessage)
                pcall(function()
                    local text = textChatMessage.Text or ""
                    if MightBeItemDrop(text) then OnItemMessage(text) end
                end)
            end))
        end
    end)

    pcall(function()
        if TextChatService then
            local function HookChannel(channel)
                if channel:IsA("TextChannel") then
                    pcall(function()
                        AddConnection(channel.MessageReceived:Connect(function(msg)
                            pcall(function()
                                local text = msg.Text or ""
                                if MightBeItemDrop(text) then OnItemMessage(text) end
                            end)
                        end))
                    end)
                end
            end
            for _, channel in ipairs(TextChatService:GetDescendants()) do
                HookChannel(channel)
            end
            AddConnection(TextChatService.DescendantAdded:Connect(function(desc)
                task.wait(0.1)
                HookChannel(desc)
            end))
        end
    end)

    pcall(function()
        local pg = LocalPlayer:WaitForChild("PlayerGui", 5)
        if not pg then return end

        local function WatchLabel(label)
            if not (label:IsA("TextLabel") or label:IsA("TextButton")) then return end
            local text = label.Text or ""
            if MightBeItemDrop(text) then OnItemMessage(text) end
            pcall(function()
                AddConnection(label:GetPropertyChangedSignal("Text"):Connect(function()
                    local newText = label.Text or ""
                    if MightBeItemDrop(newText) then OnItemMessage(newText) end
                end))
            end)
        end

        local chatFrame = pg:FindFirstChild("Chat")
        if chatFrame then
            for _, desc in ipairs(chatFrame:GetDescendants()) do
                pcall(function() WatchLabel(desc) end)
            end
            AddConnection(chatFrame.DescendantAdded:Connect(function(desc)
                task.wait(0.05)
                pcall(function() WatchLabel(desc) end)
            end))
        end

        AddConnection(pg.DescendantAdded:Connect(function(desc)
            task.wait(0.05)
            pcall(function() WatchLabel(desc) end)
        end))
    end)

    pcall(function()
        local StarterGui = game:GetService("StarterGui")
        local signal = StarterGui:GetCore("ChatWindowMessageSignal")
        if signal then
            AddConnection(signal:Connect(function(messageData)
                pcall(function()
                    local text = ""
                    if type(messageData) == "string" then
                        text = messageData
                    elseif type(messageData) == "table" then
                        text = messageData.Message or messageData.Text or messageData.message or ""
                    end
                    if MightBeItemDrop(text) then OnItemMessage(text) end
                end)
            end))
        end
    end)
end

