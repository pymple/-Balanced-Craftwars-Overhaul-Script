-- ==================== WEAPON SYSTEM ====================
-- SWORD pattern: tool.RemoteFunction:InvokeServer("hit", {80, 1})
-- GUN patterns (all confirmed from intercepts):
--   AUG:                tool.RemoteEvent:FireServer("hit", {["mhit"] = Vector3})
--   Old Construct Rifle: tool.RemoteEvent:FireServer("hit", {["mhit"] = Vector3})
--   Inglaciator:         tool.RemoteFunction:InvokeServer("shoot", {CFrame, 8})

local function GetWeaponStats()
    local weapon = GetEquippedTool()
    if not weapon then return nil end
    local stats = {}
    local damageVal = weapon:FindFirstChild("Damage")
    local critDamage = weapon:FindFirstChild("CriticalDamage")
    local critChance = weapon:FindFirstChild("CriticalChance")
    local speed = weapon:FindFirstChild("Speed") or weapon:FindFirstChild("PhysicalSwingSpeed")
    if damageVal then stats.Damage = damageVal.Value end
    if critDamage then stats.CritDamage = critDamage.Value end
    if critChance then stats.CritChance = critChance.Value end
    if speed then stats.Speed = speed.Value end
    return stats
end

local function EquipWeaponByName(weaponName)
    if not weaponName then return false end
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return false end
    local weapon = backpack:FindFirstChild(weaponName)
    if weapon and weapon:IsA("Tool") then
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum:EquipTool(weapon)
            return true
        end
    end
    return false
end

local function IsValidEnemy(obj)
    if not obj or not obj:IsA("Model") then return false end
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character == obj then return false end
    end
    local hum = obj:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end

local function GetAllEnemies()
    local enemies = {}
    for _, obj in ipairs(workspace:GetChildren()) do
        if IsValidEnemy(obj) then table.insert(enemies, obj) end
    end
    local enemyFolders = {"Enemies", "NPCs", "Mobs", "Zombies", "monsters", "Monster", "Bosses"}
    for _, folderName in ipairs(enemyFolders) do
        local folder = workspace:FindFirstChild(folderName)
        if folder then
            for _, obj in ipairs(folder:GetChildren()) do
                if IsValidEnemy(obj) then table.insert(enemies, obj) end
            end
        end
    end
    return enemies
end

local function GetEnemyHP(enemy)
    if not enemy then return 0 end
    local hum = enemy:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health or 0
end

local function GetEnemyMaxHP(enemy)
    if not enemy then return 0 end
    local hum = enemy:FindFirstChildOfClass("Humanoid")
    return hum and hum.MaxHealth or 0
end

local function IsBoss(enemy)
    if not enemy then return false end
    return GetEnemyMaxHP(enemy) > 10000
end

local function GetTargetEnemy()
    local char = LocalPlayer.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local playerPos = hrp.Position
    local enemies = GetAllEnemies()
    if #enemies == 0 then return nil end

    if Flags.TargetPriority == "Nearest" then
        local nearest, nearestDist = nil, math.huge
        for _, enemy in ipairs(enemies) do
            local part = enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Head")
            if part then
                local dist = (part.Position - playerPos).Magnitude
                if dist < nearestDist then nearestDist, nearest = dist, enemy end
            end
        end
        return nearest
    elseif Flags.TargetPriority == "Lowest HP" then
        local lowest, lowestHP = nil, math.huge
        for _, enemy in ipairs(enemies) do
            local hp = GetEnemyHP(enemy)
            if hp < lowestHP then lowestHP, lowest = hp, enemy end
        end
        return lowest
    elseif Flags.TargetPriority == "Highest HP" then
        local highest, highestHP = nil, 0
        for _, enemy in ipairs(enemies) do
            local hp = GetEnemyHP(enemy)
            if hp > highestHP then highestHP, highest = hp, enemy end
        end
        return highest
    elseif Flags.TargetPriority == "Boss First" then
        for _, enemy in ipairs(enemies) do
            if IsBoss(enemy) then return enemy end
        end
        local nearest, nearestDist = nil, math.huge
        for _, enemy in ipairs(enemies) do
            local part = enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Head")
            if part then
                local dist = (part.Position - playerPos).Magnitude
                if dist < nearestDist then nearestDist, nearest = dist, enemy end
            end
        end
        return nearest
    end
    return enemies[1]
end

local function GetCurrentTarget()
    if CurrentTarget then
        local hum = CurrentTarget:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 and CurrentTarget.Parent then return CurrentTarget end
        KillCount = KillCount + 1
        CurrentTarget = nil
    end
    CurrentTarget = GetTargetEnemy()
    return CurrentTarget
end

local function GetEnemyPosition(enemy)
    if not enemy then return nil end
    local part = enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Head")
    return part and part.Position
end

local function GetEnemyHRP(enemy)
    if not enemy then return nil end
    return enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Torso") or enemy:FindFirstChild("Head")
end

local function TeleportToTarget()
    if not Flags.AutoTeleport then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local target = GetCurrentTarget()
    if not target then return end
    local enemyPart = GetEnemyHRP(target)
    if not enemyPart then return end
    local enemyPos = enemyPart.Position
    local enemyCF = enemyPart.CFrame
    local distance = Flags.TeleportDistance
    local targetCF
    if Flags.TeleportPosition == "Back" then
        targetCF = enemyCF * CFrame.new(0, 0, distance)
    elseif Flags.TeleportPosition == "Front" then
        targetCF = enemyCF * CFrame.new(0, 0, -distance)
    elseif Flags.TeleportPosition == "Left" then
        targetCF = enemyCF * CFrame.new(-distance, 0, 0)
    elseif Flags.TeleportPosition == "Right" then
        targetCF = enemyCF * CFrame.new(distance, 0, 0)
    elseif Flags.TeleportPosition == "Top" then
        targetCF = enemyCF * CFrame.new(0, distance, 0)
    else
        targetCF = enemyCF * CFrame.new(0, 0, distance)
    end
    hrp.CFrame = CFrame.lookAt(targetCF.Position, enemyPos)
    hrp.Velocity = Vector3.new(0, 0, 0)
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
end

-- ==================== ATTACK FUNCTIONS ====================

-- AUTO SWING: Calls RemoteFunction with "hit" — melee/sword pattern
local function PerformSwordAttack()
    local tool = GetEquippedTool()
    if not tool then return end
    local rf = tool:FindFirstChild("RemoteFunction")
    if not rf then return end
    if not GetCurrentTarget() then return end
    LastEquippedWeapon = tool.Name
    pcall(function() rf:InvokeServer("hit", {80, 1}) end)
end

-- AUTO GUN: Fires at the target using ALL known gun patterns.
-- Detects which type of gun is equipped and uses the correct remote.
--
-- Type 1 (AUG, Old Construct Rifle): Has RemoteEvent
--   → RE:FireServer("hit", {["mhit"] = Vector3})
--
-- Type 2 (Inglaciator): Has GunThrowerMain LocalScript, uses RemoteFunction
--   → RF:InvokeServer("shoot", {CFrame, damage})
--   The CFrame must be from the character's position aimed at the enemy.
--   The damage arg is typically the tool's Damage value or a small int.
--
-- We detect which type and fire accordingly. We also try both as fallback.

local function PerformGunAttack()
    local tool = GetEquippedTool()
    if not tool then return end

    local target = GetCurrentTarget()
    if not target then return end
    local targetPos = GetEnemyPosition(target)
    if not targetPos then return end

    LastEquippedWeapon = tool.Name

    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local re = tool:FindFirstChild("RemoteEvent")
    local rf = tool:FindFirstChild("RemoteFunction")

    -- Get the tool's Damage value if available
    local dmgVal = tool:FindFirstChild("Damage")
    local dmg = dmgVal and dmgVal.Value or 8

    -- Detect if this is a "thrower" / projectile gun (Inglaciator type)
    local isShootGun = tool:FindFirstChild("GunThrowerMain") ~= nil
        or tool:FindFirstChild("RangedSpread") ~= nil
        or tool:FindFirstChild("RangedPower") ~= nil
        or tool:FindFirstChild("RangedProjectileAmount") ~= nil

    -- Build aim CFrame: from player position looking at enemy
    local aimCF = CFrame.lookAt(hrp.Position, targetPos)

    -- TYPE 1: RemoteEvent guns (AUG, Old Construct Rifle, etc.)
    -- Pattern: RE:FireServer("hit", {["mhit"] = Vector3})
    if re then
        pcall(function() re:FireServer("hit", {["mhit"] = targetPos}) end)
    end

    -- TYPE 2: RemoteFunction "shoot" guns (Inglaciator, etc.)
    -- Pattern: RF:InvokeServer("shoot", {CFrame, damage})
    -- Only fire "shoot" if we detected ranged properties OR there's no RemoteEvent
    -- (if a sword's RF is present we don't want to send "shoot" to it)
    if rf and (isShootGun or not re) then
        pcall(function() rf:InvokeServer("shoot", {aimCF, dmg}) end)
    end

    -- FALLBACK: If the gun has BOTH RE and RF but we're not sure which pattern,
    -- try the "shoot" on RF as well (won't hurt — pcall protects us)
    if rf and re and not isShootGun then
        pcall(function() rf:InvokeServer("shoot", {aimCF, dmg}) end)
    end
end

