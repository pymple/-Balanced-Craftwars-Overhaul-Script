local function CountMySummons()
    local count = 0
    local function Scan(container)
        for _, obj in ipairs(container:GetChildren()) do
            if obj:IsA("Model") and IsCraftwarsAlly(obj) and IsMySummon(obj) then
                local hum = obj:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 then count = count + 1 end
            end
        end
    end
    Scan(workspace)
    local folders = {"Summons", "Minions", "Allies", "Enemies", "NPCs", "Mobs"}
    for _, name in ipairs(folders) do
        local folder = workspace:FindFirstChild(name)
        if folder then Scan(folder) end
    end
    local playerFolder = workspace:FindFirstChild(LocalPlayer.Name)
    if playerFolder then Scan(playerFolder) end
    return count
end

