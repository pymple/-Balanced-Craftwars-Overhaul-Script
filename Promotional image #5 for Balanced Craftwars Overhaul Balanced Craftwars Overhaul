local function ClassifyWeapon(tool)
    if not tool then return "unknown", Flags.GunCooldown end
    if WeaponCooldownCache[tool.Name] then
        return WeaponCooldownCache[tool.Name].class, WeaponCooldownCache[tool.Name].cd
    end

    local hasRE = tool:FindFirstChild("RemoteEvent") ~= nil
    local hasRF = tool:FindFirstChild("RemoteFunction") ~= nil

    local fireRateVal = tool:FindFirstChild("FireRate")
        or tool:FindFirstChild("ShootCooldown")
        or tool:FindFirstChild("Cooldown")
        or tool:FindFirstChild("AttackSpeed")
        or tool:FindFirstChild("FireDelay")
        or tool:FindFirstChild("ShootSpeed")
        or tool:FindFirstChild("RateOfFire")

    if fireRateVal and fireRateVal:IsA("ValueBase") then
        local val = tonumber(fireRateVal.Value)
        if val and val > 0 then
            if val > 2 then val = 1 / val end
            val = math.max(val, 0.10)
            local class = val <= 0.15 and "fast_blaster" or (val <= 0.25 and "standard_gun" or "cannon")
            WeaponCooldownCache[tool.Name] = {class = class, cd = val}
            return class, val
        end
    end

    local isProjectileGun = tool:FindFirstChild("GunThrowerMain") ~= nil
        or tool:FindFirstChild("RangedSpread") ~= nil
        or tool:FindFirstChild("RangedPower") ~= nil
        or tool:FindFirstChild("RangedProjectileAmount") ~= nil
        or tool:FindFirstChild("ProjectileSpeed") ~= nil
        or tool:FindFirstChild("Cannonball") ~= nil
        or tool:FindFirstChild("Explosion") ~= nil
        or tool:FindFirstChild("ExplosionDamage") ~= nil
        or tool:FindFirstChild("BlastRadius") ~= nil

    local isFastBlaster = tool:FindFirstChild("AutoFire") ~= nil
        or tool:FindFirstChild("RapidFire") ~= nil
        or tool:FindFirstChild("BurstFire") ~= nil
        or tool:FindFirstChild("Automatic") ~= nil
        or tool:FindFirstChild("FullAuto") ~= nil

    local nameLower = tool.Name:lower()
    local fastKeywords = {"blaster", "smg", "uzi", "minigun", "auto", "rapid", "laser", "beam", "pulse", "plasma"}
    local cannonKeywords = {"cannon", "launcher", "mortar", "rocket", "breath", "hydra", "bomb", "grenade", "catapult", "ballista"}

    if not isFastBlaster then
        for _, kw in ipairs(fastKeywords) do
            if nameLower:find(kw, 1, true) then isFastBlaster = true break end
        end
    end
    if not isProjectileGun then
        for _, kw in ipairs(cannonKeywords) do
            if nameLower:find(kw, 1, true) then isProjectileGun = true break end
        end
    end

    local class, cd
    if isFastBlaster then
        class, cd = "fast_blaster", 0.10
    elseif isProjectileGun then
        class, cd = "cannon", 0.30
    elseif hasRE and not hasRF then
        class, cd = "standard_gun", 0.18
    elseif hasRF and not hasRE then
        class, cd = "cannon", 0.30
    elseif hasRE and hasRF then
        class, cd = "standard_gun", 0.18
    else
        class, cd = "unknown", Flags.GunCooldown
    end

    WeaponCooldownCache[tool.Name] = {class = class, cd = cd}
    return class, cd
end

local function GetEffectiveGunCooldown()
    if not Flags.SmartGunCooldown then return Flags.GunCooldown end
    local tool = GetEquippedTool()
    if not tool then return Flags.GunCooldown end
    local _, cd = ClassifyWeapon(tool)
    return cd
end

local function GetWeaponStats()
    local weapon = GetEquippedTool()
    if not weapon then return nil end
    local stats = {}
    local damageVal = weapon:FindFirstChild("Damage")
    local critDamage = weapon:FindFirstChild("CriticalDamage")
    local critChance = weapon:FindFirstChild("CriticalChance")
    local speed = weapon:FindFirstChild("Speed") or weapon:FindFirstChild("PhysicalSwingSpeed")
    if damageVal then stats.Damage = damageVal.Value end
    if critDamage then stats.CritDamage = critDamage.Value end
    if critChance then stats.CritChance = critChance.Value end
    if speed then stats.Speed = speed.Value end
    local class, cd = ClassifyWeapon(weapon)
    stats.WeaponClass = class
    stats.EffectiveCooldown = cd
    stats.IsSummoner = IsSummonerTool(weapon)
    return stats
end

